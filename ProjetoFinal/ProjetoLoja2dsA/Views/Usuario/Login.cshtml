@{
    ViewData["Title"] = "Entrar";
}

<link href="~/css/estilo.css" rel="stylesheet" />

<div class="auth-page">
    <h1 class="auth-title">Bem-vindo de volta</h1>

    @if (!ViewData.ModelState.IsValid)
    {
        <div style="width:clamp(320px,90vw,480px);margin-bottom:16px;padding:12px 16px;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);border-radius:14px;color:#fc8181;font-size:.88rem;">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }

    <form asp-action="Login" method="post" class="login-form">
        <div class="form-group">
            <label>E-mail</label>
            <input type="email" name="email" class="form-control" placeholder="seu@email.com" required />
        </div>

        <div class="form-group">
            <label>Senha</label>
            <input type="password" name="senha" class="form-control" placeholder="••••••••" required />
        </div>

        <button type="submit" class="btn btn-primary w-100 mt-2">
            <i class="bi bi-box-arrow-in-right me-2"></i>Entrar
        </button>

        <div class="link-abaixo">
            Não tem uma conta?
            <a asp-controller="Usuario" asp-action="Cadastro">Criar conta grátis</a>
        </div>
    </form>
</div>

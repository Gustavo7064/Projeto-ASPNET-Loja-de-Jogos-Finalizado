@model ProjetoLoja2dsA.Models.Usuario;
@{
    ViewData["Title"] = "Criar Conta";
}

<link href="~/css/estilo.css" rel="stylesheet" />
    
<div class="auth-page">
    <h1 class="auth-title">Crie sua conta</h1>

    <form asp-action="Cadastro" method="post" class="login-form">
        <div class="form-group">
            <label asp-for="Nome">Nome completo</label>
            <input asp-for="Nome" class="form-control" placeholder="Seu nome" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Email">E-mail</label>
            <input asp-for="Email" type="email" class="form-control" placeholder="seu@email.com" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Senha">Senha</label>
            <input asp-for="Senha" type="password" class="form-control" placeholder="Crie uma senha segura" />
            <span asp-validation-for="Senha" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100 mt-2">
            <i class="bi bi-person-plus me-2"></i>Criar Conta
        </button>

        <div class="link-abaixo">
            Já tem uma conta?
            <a asp-controller="Usuario" asp-action="Login">Entrar aqui</a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Carrinho";
    var usuarioId = Context.Session.GetInt32("UsuarioId");
    var usuarioLogado = usuarioId != null;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />

<style>
/* ── Zera TUDO do Bootstrap na tabela ── */
.carrinho-table {
    width: 100%;
    border-collapse: collapse;
    background: transparent !important;
    color: var(--clr-text) !important;
}
.carrinho-table thead tr {
    background: rgba(139,92,246,.07) !important;
    border-bottom: 1px solid rgba(139,92,246,.15);
}
.carrinho-table thead th {
    padding: 14px 20px;
    font-family: var(--ff-display);
    font-size: .74rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .09em;
    color: var(--clr-text-3);
    background: transparent !important;
    border: none;
}
.carrinho-table tbody tr {
    background: transparent !important;
    border-bottom: 1px solid rgba(255,255,255,.04);
    transition: background .18s;
}
.carrinho-table tbody tr:last-child { border-bottom: none; }
.carrinho-table tbody tr:hover { background: rgba(139,92,246,.05) !important; }
.carrinho-table tbody td {
    padding: 16px 20px;
    color: var(--clr-text) !important;
    background: transparent !important;
    vertical-align: middle;
    border: none;
    font-size: .95rem;
}
.carrinho-table .col-qtd { text-align: center; width: 80px; }
.carrinho-table .col-preco { text-align: right; width: 130px; font-family: var(--ff-display); font-weight: 700; color: var(--clr-neon) !important; }
.carrinho-table .col-acao { text-align: right; width: 60px; }

/* botão remover */
.btn-remover {
    background: transparent;
    border: none;
    color: rgba(248,113,113,.6);
    font-size: 1.1rem;
    cursor: pointer;
    padding: 4px 8px;
    border-radius: 8px;
    transition: color .2s, background .2s;
    line-height: 1;
}
.btn-remover:hover { color: #f87171; background: rgba(239,68,68,.1); }

/* ── Carrinho container ── */
.carrinho-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 48px 20px 60px;
}
.carrinho-container h1 {
    font-family: var(--ff-display);
    font-size: clamp(24px,4vw,34px);
    font-weight: 800;
    color: var(--clr-text);
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 14px;
}
.carrinho-container h1 i { color: var(--clr-accent); font-size: 1em; }

/* ── Card da tabela ── */
.carrinho-card {
    background: var(--clr-surface);
    border: 1px solid rgba(139,92,246,.12);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 16px 48px rgba(0,0,0,.5);
}

/* ── Empty state ── */
.carrinho-empty {
    text-align: center;
    padding: 56px 20px;
    color: var(--clr-text-3);
    font-size: .95rem;
}
.carrinho-empty i { font-size: 2.5rem; display: block; margin-bottom: 12px; opacity: .4; }

/* ── Rodapé ── */
.cart-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 28px;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,.06);
}
.total-area { display: flex; align-items: baseline; gap: 10px; }
.total-label {
    font-size: .82rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; color: var(--clr-text-3);
}
.total-value {
    font-family: var(--ff-display);
    font-size: 1.7rem; font-weight: 800; color: var(--clr-text);
}
.buttons-area { display: flex; gap: 12px; flex-wrap: wrap; }

.btn-continuar {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 24px; border-radius: 999px;
    border: 1px solid rgba(255,255,255,.18);
    background: transparent;
    color: var(--clr-text-2);
    font-family: var(--ff-body); font-size: .9rem; font-weight: 600;
    text-decoration: none;
    transition: all .22s;
    cursor: pointer;
}
.btn-continuar:hover { background: rgba(255,255,255,.05); border-color: rgba(139,92,246,.4); color: var(--clr-text); }

.btn-finalizar {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 28px; border-radius: 999px;
    border: none;
    background: linear-gradient(135deg, var(--clr-accent), var(--clr-accent-2));
    color: #fff;
    font-family: var(--ff-display); font-size: .9rem; font-weight: 700;
    cursor: pointer;
    box-shadow: 0 6px 20px rgba(139,92,246,.4);
    transition: all .22s;
}
.btn-finalizar:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(139,92,246,.55);
}
.btn-finalizar:disabled {
    opacity: .4; cursor: not-allowed; transform: none;
}

@@media (max-width: 600px) {
    .cart-footer { flex-direction: column; align-items: flex-start; }
    .buttons-area { width: 100%; flex-direction: column; }
    .btn-continuar, .btn-finalizar { width: 100%; justify-content: center; }
}
</style>

<div class="carrinho-container">
    <h1>
        <i class="bi bi-bag"></i>
        Carrinho de compras
    </h1>

    <div class="carrinho-card">
        <table class="carrinho-table">
            <thead>
                <tr>
                    <th>Produto</th>
                    <th class="col-qtd">Qtd</th>
                    <th class="col-preco">Preço</th>
                    <th class="col-acao"></th>
                </tr>
            </thead>
            <tbody id="cart-body">
                <!-- JS preenche aqui -->
            </tbody>
        </table>
    </div>

    <div class="cart-footer">
        <div class="total-area">
            <span class="total-label">Total</span>
            <span id="cart-total" class="total-value">R$ 0,00</span>
        </div>

        <div class="buttons-area">
            <a asp-controller="Home" asp-action="Index" class="btn-continuar">
                <i class="bi bi-arrow-left"></i> Continuar comprando
            </a>
            <button type="button" class="btn-finalizar" id="btn-finalizar" disabled>
                <i class="bi bi-lock"></i> Finalizar Compra
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.usuarioLogado = @(usuarioLogado.ToString().ToLower());
        window.usuarioId = @(usuarioId ?? 0);
    </script>
    <script src="~/js/carrinho.js"></script>
}

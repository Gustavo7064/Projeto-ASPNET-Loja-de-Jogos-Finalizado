@using ProjetoLoja2dsA.Models
@{
    ViewData["Title"] = "Área do Funcionário";
    Layout = "_Layout";
    var usuarios = ViewBag.Usuarios as List<ProjetoLoja2dsA.Models.Usuario> ?? new();
    var produtos = ViewBag.Produtos as List<ProjetoLoja2dsA.Models.Produto> ?? new();
}

<style>
/* ── Layout geral ── */
.func-root { padding: 40px 0 80px; }
.func-page-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    flex-wrap: wrap; gap: 16px; margin-bottom: 36px;
}
.func-page-title {
    font-family: var(--ff-display); font-size: clamp(22px,3.5vw,32px);
    font-weight: 800; margin-bottom: 4px;
}
.func-page-sub { color: var(--clr-text-2); font-size: .9rem; }
.func-badge-online {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 8px 18px; border-radius: 999px;
    background: rgba(139,92,246,.08); border: 1px solid rgba(139,92,246,.2);
    font-size: .82rem; font-weight: 700; color: var(--clr-neon);
}
.dot-pulse {
    width: 8px; height: 8px; border-radius: 50%;
    background: #22c55e; box-shadow: 0 0 8px rgba(34,197,94,.8);
    animation: pulse 2s ease-in-out infinite;
}
@@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }

/* ── Stats bar ── */
.func-stats {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 16px; margin-bottom: 32px;
}
.stat-card {
    background: var(--clr-surface); border: 1px solid rgba(255,255,255,.06);
    border-radius: 18px; padding: 22px 24px;
    box-shadow: 0 8px 24px rgba(0,0,0,.35);
    transition: border-color .2s;
}
.stat-card:hover { border-color: rgba(139,92,246,.3); }
.stat-card.purple { border-left: 3px solid #8b5cf6; }
.stat-card.green  { border-left: 3px solid #22c55e; }
.stat-card.blue   { border-left: 3px solid #38bdf8; }
.stat-label { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .09em; color: var(--clr-text-3); margin-bottom: 6px; }
.stat-value { font-family: var(--ff-display); font-size: 2rem; font-weight: 800; line-height: 1; }
.stat-sub { font-size: .8rem; color: var(--clr-text-2); margin-top: 4px; }

/* ── Alert ── */
.func-alert {
    background: rgba(34,197,94,.08); border: 1px solid rgba(34,197,94,.25);
    border-radius: 14px; padding: 14px 20px; color: #86efac;
    font-size: .9rem; font-weight: 600; margin-bottom: 24px;
    display: flex; align-items: center; gap: 10px;
}

/* ── Tabs ── */
.func-tabs {
    display: flex; gap: 4px; margin-bottom: 28px;
    background: var(--clr-surface); border-radius: 14px; padding: 6px;
    border: 1px solid rgba(255,255,255,.06);
    width: fit-content;
}
.func-tab {
    padding: 9px 22px; border-radius: 10px; font-family: var(--ff-body);
    font-size: .88rem; font-weight: 600; cursor: pointer; border: none;
    background: transparent; color: var(--clr-text-2);
    transition: all .2s;
}
.func-tab.active {
    background: linear-gradient(135deg, var(--clr-accent), var(--clr-accent-2));
    color: #fff; box-shadow: 0 4px 16px rgba(139,92,246,.35);
}
.func-tab:not(.active):hover { background: rgba(139,92,246,.1); color: var(--clr-text); }

/* ── Tab panels ── */
.func-panel { display: none; }
.func-panel.active { display: block; }

/* ── Section titles ── */
.section-card {
    background: var(--clr-surface); border: 1px solid rgba(255,255,255,.06);
    border-radius: 20px; overflow: hidden; box-shadow: 0 8px 24px rgba(0,0,0,.35);
    margin-bottom: 24px;
}
.section-card-header {
    display: flex; align-items: center; gap: 12px;
    padding: 20px 24px; border-bottom: 1px solid rgba(255,255,255,.06);
    background: rgba(139,92,246,.04);
}
.section-card-header h2 {
    font-family: var(--ff-display); font-size: 1rem; font-weight: 700; margin: 0;
}
.section-card-header .badge-count {
    padding: 3px 10px; border-radius: 999px;
    background: rgba(139,92,246,.12); border: 1px solid rgba(139,92,246,.2);
    font-size: .75rem; font-weight: 800; color: var(--clr-neon);
}

/* ── Tabela usuários ── */
.func-table { width: 100%; border-collapse: collapse; }
.func-table th {
    padding: 12px 20px; text-align: left;
    font-family: var(--ff-display); font-size: .72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .09em; color: var(--clr-text-3);
    border-bottom: 1px solid rgba(255,255,255,.06); background: transparent;
}
.func-table td {
    padding: 13px 20px; font-size: .88rem; color: var(--clr-text);
    border-bottom: 1px solid rgba(255,255,255,.04); background: transparent;
    vertical-align: middle;
}
.func-table tbody tr:last-child td { border-bottom: none; }
.func-table tbody tr:hover td { background: rgba(139,92,246,.04); }
.badge-id {
    display: inline-block; padding: 3px 9px; border-radius: 999px;
    background: rgba(139,92,246,.1); border: 1px solid rgba(139,92,246,.2);
    font-size: .75rem; font-weight: 800; color: var(--clr-neon);
}
.badge-role {
    display: inline-block; padding: 3px 10px; border-radius: 999px;
    font-size: .75rem; font-weight: 700;
}
.badge-role.func { background: rgba(139,92,246,.12); border: 1px solid rgba(139,92,246,.2); color: var(--clr-neon); }
.badge-role.user { background: rgba(56,189,248,.08); border: 1px solid rgba(56,189,248,.2); color: #7dd3fc; }
.senha-text { font-family: monospace; font-size: .82rem; color: var(--clr-text-3); letter-spacing: .05em; }
.btn-edit-sm {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 12px; border-radius: 8px; font-size: .78rem; font-weight: 600;
    background: rgba(139,92,246,.1); border: 1px solid rgba(139,92,246,.25);
    color: var(--clr-neon); text-decoration: none; cursor: pointer;
    transition: all .2s;
}
.btn-edit-sm:hover { background: rgba(139,92,246,.2); color: #fff; }

/* ── Formulário adicionar jogo ── */
.add-game-form { padding: 28px 24px; }
.form-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;
}
.form-grid.full { grid-template-columns: 1fr; }
.field-group { display: flex; flex-direction: column; gap: 7px; }
.field-group label {
    font-size: .78rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; color: var(--clr-text-3);
}
.field-group input,
.field-group textarea,
.field-group select {
    width: 100%; padding: 12px 16px; border-radius: 12px;
    border: 1px solid rgba(255,255,255,.1); background: rgba(255,255,255,.04);
    color: var(--clr-text); font-family: var(--ff-body); font-size: .92rem;
    outline: none; transition: border-color .2s, box-shadow .2s;
    box-sizing: border-box;
}
.field-group input:focus,
.field-group textarea:focus,
.field-group select:focus {
    border-color: var(--clr-accent); box-shadow: 0 0 0 3px rgba(139,92,246,.2);
    background: rgba(139,92,246,.04);
}
.field-group textarea { resize: vertical; min-height: 80px; }
.field-group select option { background: var(--clr-surface); }

/* Upload de imagem */
.upload-area {
    border: 2px dashed rgba(139,92,246,.3); border-radius: 14px;
    padding: 28px 20px; text-align: center; cursor: pointer;
    transition: all .2s; position: relative;
}
.upload-area:hover { border-color: var(--clr-accent); background: rgba(139,92,246,.04); }
.upload-area input[type="file"] {
    position: absolute; inset: 0; width: 100%; height: 100%;
    opacity: 0; cursor: pointer; border: none; background: none;
}
.upload-area i { font-size: 2rem; color: var(--clr-accent); margin-bottom: 8px; display: block; }
.upload-area p { font-size: .88rem; color: var(--clr-text-2); margin: 0; }
.upload-area small { font-size: .75rem; color: var(--clr-text-3); }
#preview-imagem {
    max-width: 120px; max-height: 120px; border-radius: 10px;
    object-fit: cover; margin: 12px auto 0; display: none; border: 2px solid rgba(139,92,246,.3);
}

.btn-add-game {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 13px 28px; border-radius: 999px; border: none;
    background: linear-gradient(135deg, var(--clr-accent), var(--clr-accent-2));
    color: #fff; font-family: var(--ff-display); font-size: .92rem; font-weight: 700;
    cursor: pointer; box-shadow: 0 6px 20px rgba(139,92,246,.4);
    transition: all .22s;
}
.btn-add-game:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(139,92,246,.55); }

/* ── Grid de jogos cadastrados ── */
.jogos-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 16px; padding: 20px 24px;
}
.jogo-card-admin {
    background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07);
    border-radius: 14px; overflow: hidden; transition: border-color .2s;
}
.jogo-card-admin:hover { border-color: rgba(139,92,246,.3); }
.jogo-card-admin img {
    width: 100%; height: 110px; object-fit: cover; display: block;
    background: var(--clr-bg);
}
.jogo-card-admin-info { padding: 10px 12px; }
.jogo-card-admin-nome { font-family: var(--ff-display); font-size: .85rem; font-weight: 700; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.jogo-card-admin-preco { font-size: .8rem; color: var(--clr-neon); font-weight: 700; margin-bottom: 8px; }
.btn-excluir-jogo {
    width: 100%; padding: 6px; border-radius: 8px; border: 1px solid rgba(239,68,68,.3);
    background: transparent; color: #fc8181; font-size: .78rem; font-weight: 600;
    cursor: pointer; transition: all .2s;
}
.btn-excluir-jogo:hover { background: rgba(239,68,68,.1); }

/* ── Modal editar usuário ── */
.modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,.7); z-index: 9999;
    display: flex; align-items: center; justify-content: center; padding: 20px;
    opacity: 0; pointer-events: none; transition: opacity .25s;
}
.modal-overlay.open { opacity: 1; pointer-events: all; }
.modal-box {
    background: var(--clr-surface); border: 1px solid rgba(139,92,246,.2);
    border-radius: 24px; padding: 36px; width: 100%; max-width: 480px;
    box-shadow: 0 32px 80px rgba(0,0,0,.7);
    transform: translateY(16px); transition: transform .25s;
}
.modal-overlay.open .modal-box { transform: none; }
.modal-title { font-family: var(--ff-display); font-size: 1.3rem; font-weight: 800; margin-bottom: 24px; }
.modal-field { margin-bottom: 16px; }
.modal-field label { display: block; font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--clr-text-3); margin-bottom: 7px; }
.modal-field input {
    width: 100%; padding: 12px 16px; border-radius: 12px;
    border: 1px solid rgba(255,255,255,.1); background: rgba(255,255,255,.04);
    color: var(--clr-text); font-family: var(--ff-body); font-size: .92rem;
    outline: none; box-sizing: border-box; transition: border-color .2s, box-shadow .2s;
}
.modal-field input:focus { border-color: var(--clr-accent); box-shadow: 0 0 0 3px rgba(139,92,246,.2); }
.modal-btns { display: flex; gap: 12px; margin-top: 24px; }
.modal-btn-save {
    flex: 1; padding: 12px; border-radius: 999px; border: none;
    background: linear-gradient(135deg, var(--clr-accent), var(--clr-accent-2));
    color: #fff; font-family: var(--ff-display); font-weight: 700; font-size: .9rem;
    cursor: pointer; transition: all .2s;
}
.modal-btn-save:hover { box-shadow: 0 8px 24px rgba(139,92,246,.5); }
.modal-btn-cancel {
    flex: 1; padding: 12px; border-radius: 999px;
    border: 1px solid rgba(255,255,255,.15); background: transparent;
    color: var(--clr-text-2); font-family: var(--ff-body); font-size: .9rem;
    cursor: pointer; transition: all .2s;
}
.modal-btn-cancel:hover { background: rgba(255,255,255,.05); color: var(--clr-text); }

@@media (max-width: 768px) {
    .form-grid { grid-template-columns: 1fr; }
    .func-table th:nth-child(4),
    .func-table td:nth-child(4) { display: none; }
}
</style>

<div class="container func-root">

    <!-- HEADER -->
    <div class="func-page-header">
        <div>
            <h1 class="func-page-title"><i class="bi bi-person-badge me-2" style="color:var(--clr-accent);"></i>Área do Funcionário</h1>
            <p class="func-page-sub">Gerencie usuários e o catálogo de jogos da RocketGames.</p>
        </div>
        <span class="func-badge-online"><span class="dot-pulse"></span>Funcionário logado</span>
    </div>

    <!-- ALERTA DE SUCESSO -->
    @if (TempData["Sucesso"] != null)
    {
        <div class="func-alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["Sucesso"]
        </div>
    }

    <!-- STATS -->
    <div class="func-stats">
        <div class="stat-card purple">
            <div class="stat-label">Usuários cadastrados</div>
            <div class="stat-value">@usuarios.Count</div>
            <div class="stat-sub">contas na plataforma</div>
        </div>
        <div class="stat-card green">
            <div class="stat-label">Jogos no catálogo</div>
            <div class="stat-value">@produtos.Count</div>
            <div class="stat-sub">títulos disponíveis</div>
        </div>
        <div class="stat-card blue">
            <div class="stat-label">Funcionário</div>
            <div class="stat-value" style="font-size:1rem;padding-top:6px;">@Context.Session.GetString("NomeUsuario")</div>
            <div class="stat-sub">@Context.Session.GetString("EmailUsuario")</div>
        </div>
    </div>

    <!-- TABS -->
    <div class="func-tabs">
        <button class="func-tab active" onclick="showTab('tab-usuarios', this)">
            <i class="bi bi-people me-2"></i>Usuários
        </button>
        <button class="func-tab" onclick="showTab('tab-jogos', this)">
            <i class="bi bi-controller me-2"></i>Catálogo de Jogos
        </button>
        <button class="func-tab" onclick="showTab('tab-adicionar', this)">
            <i class="bi bi-plus-circle me-2"></i>Adicionar Jogo
        </button>
    </div>

    <!-- TAB: USUÁRIOS -->
    <div id="tab-usuarios" class="func-panel active">
        <div class="section-card">
            <div class="section-card-header">
                <i class="bi bi-people" style="color:var(--clr-accent);font-size:1.1rem;"></i>
                <h2>Usuários cadastrados</h2>
                <span class="badge-count">@usuarios.Count</span>
            </div>
            @if (!usuarios.Any())
            {
                <div style="text-align:center;padding:48px;color:var(--clr-text-3);">Nenhum usuário cadastrado.</div>
            }
            else
            {
                <div style="overflow-x:auto;">
                    <table class="func-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nome</th>
                                <th>E-mail</th>
                                <th>Senha</th>
                                <th>Perfil</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in usuarios)
                            {
                                <tr>
                                    <td><span class="badge-id">#@u.Id</span></td>
                                    <td><strong>@u.Nome</strong></td>
                                    <td style="color:var(--clr-text-2);font-size:.85rem;">@u.Email</td>
                                    <td><span class="senha-text">@u.Senha</span></td>
                                    <td>
                                        <span class="badge-role @(u.Role == "Funcionario" ? "func" : "user")">
                                            @(u.Role ?? "user")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn-edit-sm"
                                                onclick="abrirModalEditar(@u.Id, '@u.Nome?.Replace("'","\\'")', '@u.Email?.Replace("'","\\'")', '@u.Senha?.Replace("'","\\'")')">
                                            <i class="bi bi-pencil"></i> Editar
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- TAB: CATÁLOGO DE JOGOS -->
    <div id="tab-jogos" class="func-panel">
        <div class="section-card">
            <div class="section-card-header">
                <i class="bi bi-collection" style="color:var(--clr-accent);font-size:1.1rem;"></i>
                <h2>Jogos cadastrados no banco</h2>
                <span class="badge-count">@produtos.Count</span>
            </div>
            @if (!produtos.Any())
            {
                <div style="text-align:center;padding:48px;color:var(--clr-text-3);">
                    <i class="bi bi-controller" style="font-size:2rem;display:block;margin-bottom:10px;opacity:.3;"></i>
                    Nenhum jogo cadastrado ainda.
                </div>
            }
            else
            {
                <div class="jogos-grid">
                    @foreach (var p in produtos)
                    {
                        <div class="jogo-card-admin">
                            <img src="@(string.IsNullOrEmpty(p.ImagemUrl) ? "/pastafotos/avatar-default.png" : p.ImagemUrl)"
                                 alt="@p.Nome" onerror="this.src='/pastafotos/avatar-default.png'" />
                            <div class="jogo-card-admin-info">
                                <div class="jogo-card-admin-nome" title="@p.Nome">@p.Nome</div>
                                <div class="jogo-card-admin-preco">R$ @p.Preco?.ToString("F2")</div>
                                <form asp-controller="Funcionario" asp-action="ExcluirJogo" method="post"
                                      onsubmit="return confirmarExclusao(this, '@p.Nome')">
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <button type="submit" class="btn-excluir-jogo"              >
                                        <i class="bi bi-trash me-1"></i> Remover
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- TAB: ADICIONAR JOGO -->
    <div id="tab-adicionar" class="func-panel">
        <div class="section-card">
            <div class="section-card-header">
                <i class="bi bi-plus-circle" style="color:var(--clr-accent);font-size:1.1rem;"></i>
                <h2>Adicionar novo jogo ao catálogo</h2>
            </div>

            <form asp-controller="Funcionario" asp-action="AdicionarJogo" method="post"
                  enctype="multipart/form-data" class="add-game-form">

                <div class="form-grid">
                    <div class="field-group">
                        <label>Nome do jogo *</label>
                        <input type="text" name="Nome" placeholder="Ex: God of War Ragnarök" required />
                    </div>
                    <div class="field-group">
                        <label>Preço (R$) *</label>
                        <input type="number" name="Preco" step="0.01" min="0" placeholder="0,00" required />
                    </div>
                </div>

                <div class="form-grid">
                    <div class="field-group">
                        <label>Categoria *</label>
                        <select name="Categoria" required>
                            <option value="">Selecione...</option>
                            <option>Ação</option>
                            <option>Aventura</option>
                            <option>RPG</option>
                            <option>Tiro</option>
                            <option>Indie</option>
                            <option>Luta</option>
                            <option>Terror</option>
                            <option>Estratégia</option>
                            <option>Battle Royale</option>
                            <option>Esportes</option>
                            <option>Corrida</option>
                            <option>Simulação</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label>Imagem do jogo</label>
                        <div class="upload-area" id="upload-area">
                            <input type="file" name="imagemArquivo" accept="image/*" id="input-imagem"
                                   onchange="previewImagem(this)" />
                            <i class="bi bi-image"></i>
                            <p>Clique para selecionar ou arraste a imagem</p>
                            <small>JPG, PNG, WEBP — máx. 5MB</small>
                            <img id="preview-imagem" alt="Preview" />
                        </div>
                    </div>
                </div>

                <div class="form-grid full">
                    <div class="field-group">
                        <label>Descrição *</label>
                        <textarea name="Descricao" placeholder="Descreva o jogo brevemente..." required></textarea>
                    </div>
                </div>

                <button type="submit" class="btn-add-game">
                    <i class="bi bi-plus-lg"></i> Adicionar ao catálogo
                </button>
            </form>
        </div>
    </div>

</div>

<!-- MODAL EDITAR USUÁRIO -->
<div class="modal-overlay" id="modal-editar">
    <div class="modal-box">
        <h3 class="modal-title"><i class="bi bi-pencil-square me-2" style="color:var(--clr-accent);"></i>Editar Usuário</h3>
        <form asp-controller="Funcionario" asp-action="EditarUsuario" method="post">
            <input type="hidden" name="Id" id="modal-id" />
            <div class="modal-field">
                <label>Nome</label>
                <input type="text" name="Nome" id="modal-nome" required />
            </div>
            <div class="modal-field">
                <label>E-mail</label>
                <input type="email" name="Email" id="modal-email" required />
            </div>
            <div class="modal-field">
                <label>Senha</label>
                <input type="text" name="Senha" id="modal-senha" required />
            </div>
            <div class="modal-btns">
                <button type="submit" class="modal-btn-save"><i class="bi bi-check-lg me-1"></i>Salvar</button>
                <button type="button" class="modal-btn-cancel" onclick="fecharModal()">Cancelar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
// ── Tabs ──
function showTab(id, btn) {
    document.querySelectorAll('.func-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.func-tab').forEach(b => b.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    btn.classList.add('active');
}

// ── Modal editar usuário ──
function abrirModalEditar(id, nome, email, senha) {
    document.getElementById('modal-id').value = id;
    document.getElementById('modal-nome').value = nome;
    document.getElementById('modal-email').value = email;
    document.getElementById('modal-senha').value = senha;
    document.getElementById('modal-editar').classList.add('open');
}
function fecharModal() {
    document.getElementById('modal-editar').classList.remove('open');
}
document.getElementById('modal-editar').addEventListener('click', function(e) {
    if (e.target === this) fecharModal();
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') fecharModal(); });

// ── Confirmar exclusão de jogo ──
function confirmarExclusao(form, nomeJogo) {
    return confirm(`Remover "${nomeJogo}" do catálogo?`);
}

// ── Preview imagem ──
function previewImagem(input) {
    const preview = document.getElementById('preview-imagem');
    const area = document.getElementById('upload-area');
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => {
            preview.src = e.target.result;
            preview.style.display = 'block';
            area.querySelector('i').style.display = 'none';
            area.querySelector('p').textContent = input.files[0].name;
        };
        reader.readAsDataURL(input.files[0]);
    }
}
</script>
}

@model ProjetoLoja2dsA.Models.Usuario
@{
    ViewData["Title"] = "Editar Usuário";
    Layout = "_Layout";
}

<style>
.editar-page { min-height: calc(100vh - 140px); display: flex; align-items: center; justify-content: center; padding: 40px 20px; }
.editar-card {
    width: clamp(320px, 90vw, 500px);
    background: var(--clr-surface); border: 1px solid rgba(139,92,246,.15);
    border-radius: 24px; padding: 40px 36px;
    box-shadow: 0 24px 64px rgba(0,0,0,.55);
    animation: formPop .3s cubic-bezier(.16,.84,.36,1) both;
}
@@keyframes formPop { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:none} }
.editar-card h2 { font-family: var(--ff-display); font-size: 1.4rem; font-weight: 800; text-align:center; margin-bottom: 28px; }
.form-label { display:block; font-size:.78rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:var(--clr-text-3); margin-bottom:7px; }
.form-control { width:100%; padding:12px 16px; border-radius:12px; border:1px solid rgba(255,255,255,.1); background:rgba(255,255,255,.04); color:var(--clr-text); font-family:var(--ff-body); font-size:.92rem; outline:none; box-sizing:border-box; transition:border-color .2s, box-shadow .2s; }
.form-control:focus { border-color:var(--clr-accent); box-shadow:0 0 0 3px rgba(139,92,246,.2); }
.btn-save { width:100%; padding:13px; border-radius:999px; border:none; background:linear-gradient(135deg,var(--clr-accent),var(--clr-accent-2)); color:#fff; font-family:var(--ff-display); font-size:.92rem; font-weight:700; cursor:pointer; margin-top:10px; box-shadow:0 6px 20px rgba(139,92,246,.35); transition:all .22s; }
.btn-save:hover { transform:translateY(-2px); box-shadow:0 12px 32px rgba(139,92,246,.5); }
.btn-back { width:100%; padding:12px; border-radius:999px; border:1px solid rgba(255,255,255,.15); background:transparent; color:var(--clr-text-2); font-family:var(--ff-body); font-size:.9rem; cursor:pointer; margin-top:10px; text-decoration:none; display:block; text-align:center; transition:all .2s; }
.btn-back:hover { background:rgba(255,255,255,.05); color:var(--clr-text); }
</style>

<div class="editar-page">
    <div class="editar-card">
        <h2><i class="bi bi-pencil-square me-2" style="color:var(--clr-accent);"></i>Editar Usuário</h2>
        <form asp-action="EditarUsuario" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label class="form-label">Nome</label>
                <input asp-for="Nome" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">E-mail</label>
                <input asp-for="Email" class="form-control" type="email" />
            </div>
            <div class="mb-3">
                <label class="form-label">Senha</label>
                <input asp-for="Senha" class="form-control" />
            </div>
            <button type="submit" class="btn-save"><i class="bi bi-check-lg me-2"></i>Salvar alterações</button>
            <a asp-controller="Funcionario" asp-action="AreaFuncionario" class="btn-back">← Voltar</a>
        </form>
    </div>
</div>
